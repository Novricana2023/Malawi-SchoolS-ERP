{
  "ConnectionStrings": {
    "DefaultConnection": "Server=tcp:<your-server>.database.windows.net,1433;Initial Catalog=<your-db>;User ID=<your-user>;Password=<your-password>;MultipleActiveResultSets=true;TrustServerCertificate=False;Encrypt=True;"
  },
  "Serilog": {
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "BlobStorage": {
    "ConnectionString": "DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net",
    "Container": "assignments"
  },
  "FileValidation": {
    "MaxBytes": "10485760",
    "AllowedTypes": "pdf,doc,docx,txt,zip"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}