{
  "ConnectionStrings": {
    "DefaultConnection": "Server=tcp:<your-server>.database.windows.net,1433;Initial Catalog=<your-db>;User ID=<your-user>;Password=<your-password>;MultipleActiveResultSets=true;TrustServerCertificate=False;Encrypt=True;"
  },
