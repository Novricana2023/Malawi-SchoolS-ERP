@model MaphunziroBlackboard.Domain.Entities.Course
@using MaphunziroBlackboard.Domain.Entities
@using System.Security.Claims
@{
    ViewData["Title"] = Model.Title;
    Layout = "_Layout";
}

<div class="row">
    <div class="col-lg-8">
        <!-- Course Header -->
        <div class="card border-0 bg-primary text-white mb-4">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <h1 class="display-6 fw-bold mb-2">@Model.Title</h1>
                        <p class="lead mb-2">@Model.ShortDescription</p>
                        <div class="d-flex gap-3">
                            <span class="badge bg-light text-dark">@Model.Code</span>
                            <span class="badge bg-light text-dark">@Model.Credits Credits</span>
                            <span class="badge bg-light text-dark">@Model.Type</span>
                            <span class="badge bg-light text-dark">@Model.Level</span>
                        </div>
                    </div>
                    <div class="col-md-4 text-end">
                        <div class="mb-2">
                            <i class="fas fa-users me-2"></i>
                            <strong>@Model.CurrentStudents/@Model.MaxStudents</strong> Students
                        </div>
                        <div class="progress mb-2" style="height: 8px;">
                            <div class="progress-bar bg-light" style="width: @(Model.CurrentStudents * 100.0 / Model.MaxStudents)%"></div>
                        </div>
                        <small>@((Model.CurrentStudents * 100.0 / Model.MaxStudents).ToString("F0"))% Enrolled</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Course Description -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Course Description</h5>
            </div>
            <div class="card-body">
                <p>@Html.Raw(Model.Description?.Replace("\n", "<br/>") ?? "No description available.")</p>
                
                @if (!string.IsNullOrEmpty(Model.Objectives))
                {
                    <h6>Learning Objectives</h6>
                    <p>@Html.Raw(Model.Objectives.Replace("\n", "<br/>"))</p>
                }
                
                @if (!string.IsNullOrEmpty(Model.Prerequisites))
                {
                    <h6>Prerequisites</h6>
                    <p>@Html.Raw(Model.Prerequisites.Replace("\n", "<br/>"))</p>
                }
                
                @if (!string.IsNullOrEmpty(Model.LearningOutcomes))
                {
                    <h6>Learning Outcomes</h6>
                    <p>@Html.Raw(Model.LearningOutcomes.Replace("\n", "<br/>"))</p>
                }
            </div>
        </div>

        <!-- Course Modules -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Course Modules</h5>
            </div>
            <div class="card-body">
                @if (Model.Modules.Any())
                {
                    <div class="accordion" id="modulesAccordion">
                        @foreach (var module in Model.Modules.OrderBy(m => m.Order))
                        {
                            <div class="accordion-item">
                                <h2 class="accordion-header" id="module-@module.Id">
                                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@module.Id">
                                        <div class="d-flex justify-content-between align-items-center w-100">
                                            <div>
                                                <strong>Module @module.Order: @module.Title</strong>
                                                @if (!module.IsPublished)
                                                {
                                                    <span class="badge bg-warning ms-2">Draft</span>
                                                }
                                            </div>
                                            <div>
                                                <small class="text-muted">@module.Contents.Count items</small>
                                            </div>
                                        </div>
                                    </button>
                                </h2>
                                <div id="collapse-@module.Id" class="accordion-collapse collapse" data-bs-parent="#modulesAccordion">
                                    <div class="accordion-body">
                                        @if (!string.IsNullOrEmpty(module.Description))
                                        {
                                            <p class="text-muted">@module.Description</p>
                                        }
                                        
                                        @if (module.Contents.Any())
                                        {
                                            <div class="list-group">
                                                @foreach (var content in module.Contents.OrderBy(c => c.Order))
                                                {
                                                    <div class="list-group-item d-flex justify-content-between align-items-center">
                                                        <div>
                                                            <i class="fas @(GetContentTypeIcon(content.Type)) me-2"></i>
                                                            <strong>@content.Title</strong>
                                                            @if (!content.IsPublished)
                                                            {
                                                                <span class="badge bg-warning ms-2">Draft</span>
                                                            }
                                                            <div class="text-muted small">@content.Description</div>
                                                        </div>
                                                        <div class="text-end">
                                                            <small class="text-muted">@content.DurationMinutes min</small>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <p class="text-muted">No content added yet.</p>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted text-center">No modules available yet.</p>
                }
            </div>
        </div>

        <!-- Assignments -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Assignments</h5>
            </div>
            <div class="card-body">
                @if (Model.Assignments.Any())
                {
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Title</th>
                                    <th>Due Date</th>
                                    <th>Max Score</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var assignment in Model.Assignments.OrderByDescending(a => a.DueDate))
                                {
                                    var isOverdue = assignment.DueDate < DateTime.Now;
                                    var userSubmissions = assignment.Submissions.Where(s => s.Student.UserId == User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier));
                                    var hasSubmitted = userSubmissions.Any();
                                    
                                    <tr class="@(isOverdue ? "table-danger" : "")">
                                        <td>
                                            <strong>@assignment.Title</strong>
                                            @if (!assignment.IsPublished)
                                            {
                                                <span class="badge bg-warning ms-2">Draft</span>
                                            }
                                        </td>
                                        <td>
                                            @assignment.DueDate.ToString("MMM dd, yyyy")
                                            @if (isOverdue)
                                            {
                                                <span class="badge bg-danger ms-2">Overdue</span>
                                            }
                                        </td>
                                        <td>@assignment.MaxScore</td>
                                        <td>
                                            @if (hasSubmitted)
                                            {
                                                var submission = userSubmissions.First();
                                                <span class="badge bg-success">Submitted</span>
                                                if (submission.Score.HasValue)
                                                {
                                                    <span class="badge bg-primary ms-1">Graded</span>
                                                }
                                            }
                                            else if (isOverdue)
                                            {
                                                <span class="badge bg-danger">Missed</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning">Pending</span>
                                            }
                                        </td>
                                        <td>
                                            <a href="/Assignments/Details/@assignment.Id" class="btn btn-sm btn-outline-primary">View</a>
                                            @if (User.IsInRole("Student") && !hasSubmitted && !isOverdue)
                                            {
                                                <a href="/Assignments/Submit/@assignment.Id" class="btn btn-sm btn-primary">Submit</a>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted text-center">No assignments available yet.</p>
                }
            </div>
        </div>

        <!-- Resources -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Course Resources</h5>
            </div>
            <div class="card-body">
                @if (Model.Resources.Any())
                {
                    <div class="row">
                        @foreach (var resource in Model.Resources)
                        {
                            <div class="col-md-6 mb-3">
                                <div class="d-flex align-items-center p-3 border rounded">
                                    <i class="fas @(GetResourceTypeIcon(resource.Type)) fa-2x text-primary me-3"></i>
                                    <div class="flex-grow-1">
                                        <strong>@resource.Title</strong>
                                        <div class="text-muted small">@resource.FileName</div>
                                        <div class="text-muted small">@FormatFileSize(resource.FileSize)</div>
                                    </div>
                                    <a href="/Resources/Download/@resource.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-download"></i>
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted text-center">No resources available yet.</p>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <!-- Course Info -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Course Information</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <strong>Course Code:</strong>
                    <div>@Model.Code</div>
                </div>
                <div class="mb-3">
                    <strong>Credits:</strong>
                    <div>@Model.Credits</div>
                </div>
                <div class="mb-3">
                    <strong>Type:</strong>
                    <div>@Model.Type</div>
                </div>
                <div class="mb-3">
                    <strong>Level:</strong>
                    <div>@Model.Level</div>
                </div>
                <div class="mb-3">
                    <strong>Status:</strong>
                    <div>
                        <span class="badge @(Model.IsPublished ? "bg-success" : "bg-warning")">
                            @(Model.IsPublished ? "Published" : "Draft")
                        </span>
                    </div>
                </div>
                @if (Model.Department != null)
                {
                    <div class="mb-3">
                        <strong>Department:</strong>
                        <div>@Model.Department.Name</div>
                    </div>
                }
            </div>
        </div>

        <!-- Teachers -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Course Teachers</h5>
            </div>
            <div class="card-body">
                @if (Model.TeacherCourses.Any())
                {
                    @foreach (var teacherCourse in Model.TeacherCourses)
                    {
                        <div class="d-flex align-items-center mb-3">
                            <div class="bg-primary text-white rounded-circle p-2 me-3" style="width: 40px; height: 40px;">
                                <i class="fas fa-chalkboard-teacher"></i>
                            </div>
                            <div>
                                <strong>@teacherCourse.Teacher.FullName</strong>
                                <div class="text-muted small">@teacherCourse.Teacher.Specialization</div>
                                <div class="text-muted small">Since @teacherCourse.StartDate.ToString("MMM yyyy")</div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted">No teachers assigned yet.</p>
                }
            </div>
        </div>

        <!-- Enrollment Actions -->
        @if (User.IsInRole("Student"))
        {
            var userId = User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);
            var isEnrolled = Model.StudentCourses.Any(sc => sc.Student.UserId == userId && !sc.IsDeleted);
            
            <div class="card mb-4">
                <div class="card-body">
                    @if (isEnrolled)
                    {
                        <form asp-action="Unenroll" asp-route-id="@Model.Id" method="post">
                            <button type="submit" class="btn btn-warning w-100" onclick="return confirm('Are you sure you want to unenroll from this course?')">
                                <i class="fas fa-sign-out-alt me-2"></i>Unenroll from Course
                            </button>
                        </form>
                    }
                    else if (Model.IsPublished && Model.CurrentStudents < Model.MaxStudents)
                    {
                        <form asp-action="Enroll" asp-route-id="@Model.Id" method="post">
                            <button type="submit" class="btn btn-success w-100">
                                <i class="fas fa-plus me-2"></i>Enroll in Course
                            </button>
                        </form>
                    }
                    else if (!Model.IsPublished)
                    {
                        <button class="btn btn-secondary w-100" disabled>
                            <i class="fas fa-lock me-2"></i>Course Not Published
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-secondary w-100" disabled>
                            <i class="fas fa-users me-2"></i>Course Full
                        </button>
                    }
                </div>
            </div>
        }

        <!-- Quick Actions -->
        @if (User.IsInRole("SuperAdmin") || User.IsInRole("SchoolAdmin") || User.IsInRole("Teacher"))
        {
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a href="/Courses/Edit/@Model.Id" class="btn btn-outline-primary">
                            <i class="fas fa-edit me-2"></i>Edit Course
                        </a>
                        <a href="/Modules/Create?courseId=@Model.Id" class="btn btn-outline-success">
                            <i class="fas fa-plus me-2"></i>Add Module
                        </a>
                        <a href="/Assignments/Create?courseId=@Model.Id" class="btn btn-outline-warning">
                            <i class="fas fa-tasks me-2"></i>Create Assignment
                        </a>
                        <a href="/Resources/Create?courseId=@Model.Id" class="btn btn-outline-info">
                            <i class="fas fa-file me-2"></i>Add Resource
                        </a>
                        <a href="/Announcements/Create?courseId=@Model.Id" class="btn btn-outline-secondary">
                            <i class="fas fa-bullhorn me-2"></i>Make Announcement
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@functions {
    public string GetContentTypeIcon(ContentType type)
    {
        return type switch
        {
            ContentType.Text => "fa-file-alt",
            ContentType.Video => "fa-video",
            ContentType.Audio => "fa-audio",
            ContentType.PDF => "fa-file-pdf",
            ContentType.Document => "fa-file-word",
            ContentType.Presentation => "fa-file-powerpoint",
            ContentType.Image => "fa-image",
            ContentType.Link => "fa-link",
            ContentType.Quiz => "fa-question-circle",
            ContentType.Assignment => "fa-tasks",
            _ => "fa-file"
        };
    }

    public string GetResourceTypeIcon(ResourceType type)
    {
        return type switch
        {
            ResourceType.Document => "fa-file-alt",
            ResourceType.Video => "fa-video",
            ResourceType.Audio => "fa-audio",
            ResourceType.Image => "fa-image",
            ResourceType.Link => "fa-link",
            ResourceType.Presentation => "fa-file-powerpoint",
            ResourceType.Spreadsheet => "fa-file-excel",
            ResourceType.Archive => "fa-file-archive",
            _ => "fa-file"
        };
    }

    public string FormatFileSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }
}
