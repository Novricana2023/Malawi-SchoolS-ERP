@model List<MaphunziroBlackboard.Domain.Entities.AssignmentSubmission>
@{
    ViewData["Title"] = "Submissions";
    Layout = "_Layout";
}

<div class="container">
    <h2>Submissions</h2>
    <table class="table">
        <thead>
            <tr>
                <th>Student</th>
                <th>Submitted At</th>
                <th>File</th>
                <th>Score</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach(var s in Model)
            {
                <tr>
                    <td>@s.Student?.FullName ?? "-"</td>
                    <td>@s.SubmittedAt.ToLocalTime().ToString("g")</td>
                    <td>
                        @if(!string.IsNullOrEmpty(s.FilePath)) {
                            <a href="@s.FilePath" target="_blank">Download</a>
                        } else {
                            <span class="text-muted">No file</span>
                        }
                    </td>
                    <td>@(s.Score?.ToString() ?? "-")</td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary" href="/Assignments/Grade?id=@s.Id">Grade</a>
                        <form method="post" asp-action="DeleteSubmission" style="display:inline-block;" onsubmit="return confirm('Delete submission?');">
                            <input type="hidden" name="id" value="@s.Id" />
                            <button class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>