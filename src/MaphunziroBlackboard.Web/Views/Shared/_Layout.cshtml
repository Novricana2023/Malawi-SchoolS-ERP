<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Maphunziro Board</title>
    <link rel="icon" type="image/svg+xml" href="~/images/branding/maphunziro-logo.svg">
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    
    <!-- FullCalendar -->
    <link href='https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.css' rel='stylesheet' />
    
    <!-- Select2 -->
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    
    <!-- SweetAlert2 -->
    <link href='https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css' rel='stylesheet'>
    
    <!-- Custom CSS -->
    <link href="~/css/site.css" rel="stylesheet" />
    
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary fixed-top">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="~/images/branding/maphunziro-logo.svg" alt="Maphunziro Board" height="40" width="40" class="me-2 brand-logo-img">
                <span class="fw-bold">Maphunziro Board</span>
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/"><i class="fas fa-home me-1"></i> Home</a>
                    </li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Dashboard"><i class="fas fa-tachometer-alt me-1"></i> Dashboard</a>
                        </li>
                        @if (User.IsInRole("Teacher"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/Teaching"><i class="fas fa-chalkboard-teacher me-1"></i> Teaching</a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link" href="/Courses"><i class="fas fa-book me-1"></i> Courses</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Assignments"><i class="fas fa-tasks me-1"></i> Assignments</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Calendar"><i class="fas fa-calendar me-1"></i> Calendar</a>
                        </li>
                    }
                </ul>
                
                <ul class="navbar-nav">
                    <!-- Notifications -->
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link position-relative" href="#" id="notificationDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-bell"></i>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="notificationCount">0</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end notification-dropdown" style="width: 350px; max-height: 400px; overflow-y: auto;">
                                <li class="dropdown-header"><i class="fas fa-bell me-2"></i> Notifications</li>
                                <li><hr class="dropdown-divider"></li>
                                <li id="notificationList">
                                    <div class="text-center p-3">
                                        <i class="fas fa-bell-slash fa-2x text-muted"></i>
                                        <p class="text-muted mt-2">No new notifications</p>
                                    </div>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-center" href="/Notifications">View All Notifications</a></li>
                            </ul>
                        </li>
                        
                        <!-- User Menu -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-user-circle me-1"></i> @User.Identity?.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="/Profile"><i class="fas fa-user me-2"></i> Profile</a></li>
                                <li><a class="dropdown-item" href="/Settings"><i class="fas fa-cog me-2"></i> Settings</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/Account/Logout"><i class="fas fa-sign-out-alt me-2"></i> Logout</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Account/Login"><i class="fas fa-sign-in-alt me-1"></i> Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Account/Register"><i class="fas fa-building me-1"></i> Institution signup</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="container-fluid" style="margin-top: 70px;">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="row">
                <!-- Sidebar -->
                <div class="col-md-2 sidebar">
                    <div class="sidebar-sticky">
                        <ul class="nav flex-column sidebar-nav">
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")" href="/Dashboard">
                                    <i class="fas fa-tachometer-alt me-2"></i> Dashboard
                                </a>
                            </li>
                            @if (User.IsInRole("Teacher"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Teaching" ? "active" : "")" href="/Teaching">
                                        <i class="fas fa-chalkboard-teacher me-2"></i> Teaching
                                    </a>
                                </li>
                            }
                            
                            @if (User.IsInRole("SuperAdmin") || User.IsInRole("SchoolAdmin") || User.IsInRole("Registrar"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Students" ? "active" : "")" href="/Students">
                                        <i class="fas fa-graduation-cap me-2"></i> Students
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Teachers" ? "active" : "")" href="/Teachers">
                                        <i class="fas fa-chalkboard-teacher me-2"></i> Teachers
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Parents" ? "active" : "")" href="/Parents">
                                        <i class="fas fa-users me-2"></i> Parents
                                    </a>
                                </li>
                            }
                            @if (User.IsInRole("SuperAdmin") || User.IsInRole("SchoolAdmin") || User.IsInRole("Teacher") || User.IsInRole("Registrar"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Classes" ? "active" : "")" href="/Classes">
                                        <i class="fas fa-school me-2"></i> Classes
                                    </a>
                                </li>
                            }
                            
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Courses" ? "active" : "")" href="/Courses">
                                    <i class="fas fa-book me-2"></i> Courses
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Assignments" ? "active" : "")" href="/Assignments">
                                    <i class="fas fa-tasks me-2"></i> Assignments
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Exams" ? "active" : "")" href="/Exams">
                                    <i class="fas fa-file-alt me-2"></i> Exams
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Grades" ? "active" : "")" href="/Grades">
                                    <i class="fas fa-chart-line me-2"></i> Grades
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Attendance" ? "active" : "")" href="/Attendance">
                                    <i class="fas fa-user-check me-2"></i> Attendance
                                </a>
                            </li>
                            
                            @if (User.IsInRole("SuperAdmin") || User.IsInRole("SchoolAdmin") || User.IsInRole("Accountant"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Finance" ? "active" : "")" href="/Finance">
                                        <i class="fas fa-dollar-sign me-2"></i> Finance
                                    </a>
                                </li>
                            }
                            
                            @if (User.IsInRole("SuperAdmin") || User.IsInRole("SchoolAdmin") || User.IsInRole("Librarian"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Library" ? "active" : "")" href="/Library">
                                        <i class="fas fa-book-open me-2"></i> Library
                                    </a>
                                </li>
                            }
                            
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Calendar" ? "active" : "")" href="/Calendar">
                                    <i class="fas fa-calendar me-2"></i> Calendar
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Messages" ? "active" : "")" href="/Messages">
                                    <i class="fas fa-envelope me-2"></i> Messages
                                </a>
                            </li>
                            
                            @if (User.IsInRole("SuperAdmin") || User.IsInRole("SchoolAdmin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Reports" ? "active" : "")" href="/Reports">
                                        <i class="fas fa-chart-bar me-2"></i> Reports
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Settings" ? "active" : "")" href="/Settings">
                                        <i class="fas fa-cogs me-2"></i> Settings
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
                
                <!-- Content -->
                <div class="col-md-10 content">
                    @RenderBody()
                </div>
            </div>
        }
        else
        {
            @RenderBody()
        }
    </main>

    <!-- Footer -->
    <footer class="bg-dark text-light text-center py-3 mt-5">
        <div class="container">
            <p class="mb-0">&copy; 2026 Maphunziro Board. All rights reserved.</p>
            <p class="mb-0">Empowering Education in Malawi</p>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src='https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.js'></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src='https://cdn.jsdelivr.net/npm/sweetalert2@11'></script>
    
    <!-- SignalR -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    
    <!-- Custom JavaScript -->
    <script src="~/js/site.js"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
