@using MaphunziroBlackboard.Web.Models
@using MaphunziroBlackboard.Domain.Entities
@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_Layout";
}

<div class="container-fluid">
    <!-- Welcome Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 bg-primary text-white">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-md-8">
                            <h1 class="display-6 fw-bold mb-2">Welcome back, @Model.UserName.Split(' ').FirstOrDefault()!</h1>
                            <p class="lead mb-0">
                                @if (Model.UserRoles.Contains("SuperAdmin") || Model.UserRoles.Contains("SchoolAdmin"))
                                {
                                    <text>Configure your institution and invite staff and learners. Performance and analytics will appear here as your data grows.</text>
                                }
                                else if (Model.UserRoles.Contains("Teacher"))
                                {
                                    <text>Plan lessons and follow learner work — open Faculty workspace for your full teaching hub.</text>
                                }
                                else if (Model.UserRoles.Contains("Student"))
                                {
                                    <text>Keep up with your assignments and track your progress.</text>
                                }
                                else if (Model.UserRoles.Contains("Parent"))
                                {
                                    <text>Stay informed about your children's education.</text>
                                }
                                else
                                {
                                    <text>Welcome to your dashboard.</text>
                                }
                            </p>
                        </div>
                        <div class="col-md-4 text-end">
                            <div class="d-flex align-items-center justify-content-end">
                                <i class="fas fa-user-circle fa-3x me-3"></i>
                                <div>
                                    <small class="d-block">Last login</small>
                                    <strong>@DateTime.Now.ToString("MMM dd, yyyy")</strong>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Admin Dashboard -->
    @if (Model.UserRoles.Contains("SuperAdmin") || Model.UserRoles.Contains("SchoolAdmin"))
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="alert alert-light border shadow-sm mb-0">
                    <strong class="d-block mb-1">Getting started</strong>
                    <span class="text-muted">Institution-wide counts, charts, and trend analytics are not shown yet — they will surface under Performance as learners, attendance, and grades accumulate.</span>
                </div>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-lg-8 mb-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white">
                        <h5 class="mb-0">Quick actions</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-sm-6">
                                <a href="/Students/Create" class="btn btn-outline-primary w-100">
                                    <i class="fas fa-user-plus me-2"></i>Add learner
                                </a>
                            </div>
                            <div class="col-sm-6">
                                <a href="/Teachers/Create" class="btn btn-outline-success w-100">
                                    <i class="fas fa-chalkboard-teacher me-2"></i>Add teacher
                                </a>
                            </div>
                            <div class="col-sm-6">
                                <a href="/Courses/Create" class="btn btn-outline-warning w-100">
                                    <i class="fas fa-book me-2"></i>Create course
                                </a>
                            </div>
                            <div class="col-sm-6">
                                <a href="/Announcements/Create" class="btn btn-outline-info w-100">
                                    <i class="fas fa-bullhorn me-2"></i>Announcement
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 mb-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white">
                        <h5 class="mb-0">Institution setup</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted small mb-3">Invite school admins, configure classes and terms, then onboard teachers before opening registration to families.</p>
                        <a href="/Settings" class="btn btn-primary btn-sm w-100 mb-2"><i class="fas fa-cogs me-1"></i> Settings</a>
                        <a href="/Classes" class="btn btn-outline-secondary btn-sm w-100"><i class="fas fa-school me-1"></i> Classes</a>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Teacher Dashboard -->
    @if (Model.UserRoles.Contains("Teacher"))
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="alert alert-primary border-0 d-flex flex-wrap align-items-center justify-content-between gap-2 mb-0">
                    <span><strong>Faculty workspace</strong> — timetable, your courses, classes, and submissions in one place.</span>
                    <a href="/Teaching" class="btn btn-light btn-sm"><i class="fas fa-chalkboard-teacher me-1"></i> Open teaching hub</a>
                </div>
            </div>
        </div>

        <!-- Today's Schedule -->
        <div class="row mb-4">
            <div class="col-lg-6 mb-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Today's Schedule</h5>
                    </div>
                    <div class="card-body">
                        @if (Model.TodaySchedule.Any())
                        {
                            <div class="schedule-list">
                                @foreach (var item in Model.TodaySchedule)
                                {
                                    <div class="d-flex justify-content-between align-items-center mb-3 p-3 bg-light rounded">
                                        <div>
                                            <strong>@item.Subject</strong>
                                            <div class="text-muted small">@item.Class</div>
                                        </div>
                                        <div class="text-end">
                                            <div class="fw-semibold">@item.TimeRange</div>
                                            <div class="text-muted small">@item.Room</div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted text-center">No classes scheduled for today.</p>
                        }
                    </div>
                </div>
            </div>
            
            <div class="col-lg-6 mb-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Recent Assignments</h5>
                    </div>
                    <div class="card-body">
                        @if (Model.MyAssignments.Any())
                        {
                            <div class="assignment-list">
                                @foreach (var assignment in Model.MyAssignments.Take(5))
                                {
                                    <div class="d-flex justify-content-between align-items-center mb-3 p-3 border rounded">
                                        <div>
                                            <strong>@assignment.Title</strong>
                                            <div class="text-muted small">@(assignment.Course?.Title ?? "Course")</div>
                                        </div>
                                        <div class="text-end">
                                            <div class="small text-muted">Due</div>
                                            <div class="fw-semibold">@assignment.DueDate.ToString("MMM dd")</div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted text-center">No assignments created yet.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Student Dashboard -->
    @if (Model.UserRoles.Contains("Student"))
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="alert alert-light border mb-0">
                    <strong class="d-block mb-1">Your work</strong>
                    <span class="text-muted small">Summary scores and attendance trends will appear under Performance once your teachers record grades and attendance.</span>
                </div>
            </div>
        </div>

        <!-- Recent Grades and Assignments -->
        <div class="row mb-4">
            <div class="col-lg-6 mb-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Recent Grades</h5>
                    </div>
                    <div class="card-body">
                        @if (Model.MyGrades.Any())
                        {
                            <div class="grade-list">
                                @foreach (var grade in Model.MyGrades.Take(5))
                                {
                                    <div class="d-flex justify-content-between align-items-center mb-3 p-3 bg-light rounded">
                                        <div>
                                            <strong>@grade.AssignmentTitle</strong>
                                            <div class="text-muted small">@grade.CourseTitle</div>
                                        </div>
                                        <div class="text-end">
                                            <div class="fw-semibold">@grade.Score/@grade.MaxScore</div>
                                            <div class="badge bg-success">@grade.Percentage.ToString("F1")%</div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted text-center">No grades available yet.</p>
                        }
                    </div>
                </div>
            </div>
            
            <div class="col-lg-6 mb-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Upcoming Assignments</h5>
                    </div>
                    <div class="card-body">
                        @if (Model.MyAssignments.Any())
                        {
                            <div class="assignment-list">
                                @foreach (var assignment in Model.MyAssignments.Take(5))
                                {
                                    var isOverdue = assignment.DueDate < DateTime.Now;
                                    var statusLabel = isOverdue ? "Overdue" : (assignment.IsPublished ? "Open" : "Draft");
                                    <div class="d-flex justify-content-between align-items-center mb-3 p-3 border rounded @(isOverdue ? "border-danger" : "")">
                                        <div>
                                            <strong>@assignment.Title</strong>
                                            <div class="text-muted small">@(assignment.Course?.Title ?? "Course")</div>
                                        </div>
                                        <div class="text-end">
                                            <div class="small text-muted">Due</div>
                                            <div class="fw-semibold @(isOverdue ? "text-danger" : "")">@assignment.DueDate.ToString("MMM dd")</div>
                                            <div class="badge @(isOverdue ? "bg-danger" : assignment.IsPublished ? "bg-success" : "bg-secondary")">
                                                @statusLabel
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted text-center">No upcoming assignments.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Parent Dashboard -->
    @if (Model.UserRoles.Contains("Parent"))
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">My Children</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            @if (!Model.MyChildren.Any())
                            {
                                <div class="col-12">
                                    <div class="alert alert-light border mb-0">
                                        Your parent account is active. A school administrator can now link your child profiles.
                                    </div>
                                </div>
                            }
                            @foreach (var child in Model.MyChildren)
                            {
                                <div class="col-lg-4 col-md-6 mb-4">
                                    <div class="card h-100">
                                        <div class="card-body text-center">
                                            <div class="mb-3">
                                                <i class="fas fa-user-graduate fa-3x text-primary"></i>
                                            </div>
                                            <h5 class="card-title">@child.FullName</h5>
                                            <p class="text-muted">@child.StudentNumber</p>
                                            @if (child.CurrentClass != null)
                                            {
                                                <p class="badge bg-primary">@child.CurrentClass.Name</p>
                                            }
                                            <div class="mt-3">
                                                <a href="/Students/Details/@child.Id" class="btn btn-sm btn-outline-primary">View Details</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Activities -->
        <div class="row mb-4">
            <div class="col-lg-6 mb-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Recent Attendance</h5>
                    </div>
                    <div class="card-body">
                        @if (Model.ChildrenAttendance.Any())
                        {
                            <div class="attendance-list">
                                @foreach (var attendance in Model.ChildrenAttendance.Take(5))
                                {
                                    <div class="d-flex justify-content-between align-items-center mb-3 p-3 bg-light rounded">
                                        <div>
                                            <strong>@attendance.Student.FullName</strong>
                                            <div class="text-muted small">@attendance.Date.ToString("MMM dd, yyyy")</div>
                                        </div>
                                        <div>
                                            <span class="badge @(attendance.Status == AttendanceStatus.Present ? "bg-success" : "bg-warning")">
                                                @attendance.Status.ToString()
                                            </span>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted text-center">No recent attendance records.</p>
                        }
                    </div>
                </div>
            </div>
            
            <div class="col-lg-6 mb-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Recent Grades</h5>
                    </div>
                    <div class="card-body">
                        @if (Model.ChildrenGrades.Any())
                        {
                            <div class="grade-list">
                                @foreach (var grade in Model.ChildrenGrades.Take(5))
                                {
                                    var maxPts = grade.Assignment.MaxScore;
                                    var pct = maxPts > 0 && grade.Score.HasValue
                                        ? (double)(grade.Score!.Value * 100m / maxPts)
                                        : (double?)null;
                                    <div class="d-flex justify-content-between align-items-center mb-3 p-3 bg-light rounded">
                                        <div>
                                            <strong>@grade.Assignment.Title</strong>
                                            <div class="text-muted small">@grade.Student.FullName • @grade.Assignment.Course.Title</div>
                                        </div>
                                        <div class="text-end">
                                            <div class="fw-semibold">@grade.Score/@grade.Assignment.MaxScore</div>
                                            <div class="badge bg-success">@(pct.HasValue ? pct.Value.ToString("F1") : "—")%</div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted text-center">No grades available yet.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>
