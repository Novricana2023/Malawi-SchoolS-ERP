@{
    ViewData["Title"] = "Welcome to Maphunziro Board";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <meta name="description" content="Maphunziro Board — school and college ERP and learning platform built for institutions in Malawi.">
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    
    <!-- AOS Animation -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    
    <!-- Custom CSS -->
    <link href="~/css/site.css" rel="stylesheet" />
    
    <style>
        .hero-section {
            background: linear-gradient(135deg, #0066cc 0%, #0052a3 50%, #003d7a 100%);
            color: white;
            padding: 120px 0 80px;
            position: relative;
            overflow: hidden;
        }
        
        .hero-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320"><path fill="%23ffffff" fill-opacity="0.1" d="M0,96L48,112C96,128,192,160,288,160C384,160,480,128,576,122.7C672,117,768,139,864,138.7C960,139,1056,117,1152,112C1248,107,1344,117,1392,122.7L1440,128L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path></svg>') no-repeat bottom;
            background-size: cover;
        }
        
        .hero-content {
            position: relative;
            z-index: 2;
        }
        
        .feature-card {
            background: white;
            border-radius: 15px;
            padding: 2rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
            height: 100%;
        }
        
        .feature-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.15);
        }
        
        .feature-icon {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: linear-gradient(135deg, #0066cc, #0052a3);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            margin: 0 auto 1.5rem;
        }
        
        .cta-section {
            background: linear-gradient(135deg, #ff6b35, #ff8c42);
            color: white;
            padding: 80px 0;
        }
        
        .btn-hero {
            background: white;
            color: #0066cc;
            padding: 15px 40px;
            border-radius: 50px;
            font-weight: 600;
            text-decoration: none;
            display: inline-block;
            transition: all 0.3s ease;
            border: 2px solid white;
        }
        
        .btn-hero:hover {
            background: transparent;
            color: white;
            transform: translateY(-3px);
        }
        
        .btn-outline-hero {
            background: transparent;
            color: white;
            padding: 15px 40px;
            border-radius: 50px;
            font-weight: 600;
            text-decoration: none;
            display: inline-block;
            transition: all 0.3s ease;
            border: 2px solid white;
        }
        
        .btn-outline-hero:hover {
            background: white;
            color: #0066cc;
            transform: translateY(-3px);
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top" style="background: rgba(0, 102, 204, 0.95); backdrop-filter: blur(10px);">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="~/images/branding/maphunziro-logo.svg" alt="Maphunziro Board" height="40" class="me-2">
                <span class="fw-bold">Maphunziro Board</span>
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="#features">Features</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#about">About</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#institutions">For institutions</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Account/Login">Login</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-warning ms-2" href="/Account/Register">Institution signup</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero-section">
        <div class="container">
            <div class="row align-items-center hero-content">
                <div class="col-lg-6" data-aos="fade-right">
                    <h1 class="display-4 fw-bold mb-4">Run your school on Maphunziro Board</h1>
                    <p class="lead mb-4">A single platform for timetables, courses, assignments, and administration — designed for <strong>schools and colleges</strong> that want structure without noise. We are building with early partner institutions; public roll-up stats are not shown on this site yet.</p>
                    <div class="d-flex gap-3">
                        <a href="/Account/Register" class="btn-hero">Request institution access</a>
                        <a href="#features" class="btn-outline-hero">See features</a>
                    </div>
                </div>
                <div class="col-lg-6" data-aos="fade-left">
                    <img src="~/images/branding/maphunziro-logo.svg" alt="Maphunziro Board" class="img-fluid rounded-3 shadow-lg">
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="py-5">
        <div class="container">
            <div class="text-center mb-5" data-aos="fade-up">
                <h2 class="display-5 fw-bold mb-3">Powerful Features for Modern Education</h2>
                <p class="lead text-muted">Everything you need to manage your school efficiently</p>
            </div>
            
            <div class="row g-4">
                <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-graduation-cap"></i>
                        </div>
                        <h4>Student Management</h4>
                        <p>Complete student information system with admissions, profiles, attendance, and academic records.</p>
                    </div>
                </div>
                
                <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="200">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-book-open"></i>
                        </div>
                        <h4>Learning management</h4>
                        <p>Courses, assignments, quizzes, and resources in one place for teachers and learners.</p>
                    </div>
                </div>
                
                <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="300">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-chart-line"></i>
                        </div>
                        <h4>Grades & performance</h4>
                        <p>Structured grading and reporting. Institution-wide analytics will roll out as Performance once real academic data is flowing.</p>
                    </div>
                </div>
                
                <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="400">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-dollar-sign"></i>
                        </div>
                        <h4>Finance Management</h4>
                        <p>Fee structures, invoicing, payment processing, and financial reporting.</p>
                    </div>
                </div>
                
                <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="500">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-users"></i>
                        </div>
                        <h4>Parent Portal</h4>
                        <p>Real-time access to student progress, attendance, grades, and communication.</p>
                    </div>
                </div>
                
                <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="600">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-mobile-alt"></i>
                        </div>
                        <h4>Mobile Friendly</h4>
                        <p>Fully responsive design that works perfectly on smartphones, tablets, and desktops.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Institutions -->
    <section id="institutions" class="py-5 bg-light">
        <div class="container">
            <div class="text-center mb-5" data-aos="fade-up">
                <h2 class="display-5 fw-bold mb-3">Built for institutions first</h2>
                <p class="lead text-muted mb-0">Maphunziro Board is aimed at <strong>schools and colleges</strong> — not anonymous mass signups. Your leadership team registers the tenant, invites administrators and faculty, then learners and parents follow through controlled onboarding.</p>
            </div>
            <div class="row justify-content-center">
                <div class="col-lg-8" data-aos="fade-up">
                    <div class="feature-card">
                        <div class="feature-icon mx-auto"><i class="fas fa-building"></i></div>
                        <h4 class="text-center mb-3">How joining works</h4>
                        <ul class="list-unstyled mb-0">
                            <li class="mb-3"><i class="fas fa-check-circle text-success me-2"></i><strong>Institution signup</strong> — create the first administrative accounts for your organization.</li>
                            <li class="mb-3"><i class="fas fa-check-circle text-success me-2"></i><strong>Structure</strong> — academic years, classes, and staff roles are configured before day-to-day teaching traffic.</li>
                            <li class="mb-0"><i class="fas fa-check-circle text-success me-2"></i><strong>Teaching hub</strong> — lecturers use the dedicated <strong>Teaching</strong> workspace for timetables, courses, and assignments.</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
        <div class="container text-center">
            <h2 class="display-5 fw-bold mb-4" data-aos="fade-up">Bring your institution onto Maphunziro Board</h2>
            <p class="lead mb-4" data-aos="fade-up" data-aos-delay="100">Start with institution signup — we are onboarding partner schools and colleges as the product matures.</p>
            <div data-aos="fade-up" data-aos-delay="200">
                <a href="/Account/Register" class="btn-hero me-3">Institution signup</a>
                <a href="#institutions" class="btn-outline-hero">Read how it works</a>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-dark text-light text-center py-4">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-3">
                    <h5>Maphunziro Board</h5>
                    <p class="text-muted">Empowering Education in Malawi</p>
                </div>
                <div class="col-md-4 mb-3">
                    <h5>Quick Links</h5>
                    <ul class="list-unstyled">
                        <li><a href="/Account/Login" class="text-light text-decoration-none">Login</a></li>
                        <li><a href="/Account/Register" class="text-light text-decoration-none">Institution signup</a></li>
                        <li><a href="#" class="text-light text-decoration-none">Support</a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-3">
                    <h5>Contact</h5>
                    <p class="text-muted">
                        <i class="fas fa-envelope me-2"></i>info@maphunziro.com<br>
                        <i class="fas fa-phone me-2"></i>+265 1 234 567<br>
                        <i class="fas fa-map-marker-alt me-2"></i>Lilongwe, Malawi
                    </p>
                </div>
            </div>
            <hr class="bg-light">
            <p class="mb-0">&copy; 2026 Maphunziro Board. All rights reserved.</p>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    
    <script>
        // Initialize AOS
        AOS.init({
            duration: 1000,
            once: true,
            offset: 100
        });

        // Smooth scrolling for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });

        // Navbar background on scroll
        window.addEventListener('scroll', function() {
            const navbar = document.querySelector('.navbar');
            if (window.scrollY > 50) {
                navbar.style.background = 'rgba(0, 102, 204, 1)';
            } else {
                navbar.style.background = 'rgba(0, 102, 204, 0.95)';
            }
        });
    </script>
</body>
</html>
